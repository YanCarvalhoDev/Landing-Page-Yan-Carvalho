  </head>

  <body class="min-h-screen bg-zinc-950 text-white font-sans antialiased selection:bg-cyan-500 selection:text-black">
 <Header client:load />

<main class="relative">
  <Hero client:load />
  <Tension client:visible />
  <InlineCTA client:visible text="Quero resolver isso agora" subtitle="Seja encontrado no Google e converta mais visitas em faturamento" isSpace={true} />
  <Portfolio client:visible />
  <InlineCTA client:visible text="Quero um projeto assim" subtitle="Design sob medida focado em velocidade e conversão de elite" />
  <Services client:visible />
  <Qualify client:visible />
  <InlineCTA client:visible text="Falar com Especialista" subtitle="Atendimento humanizado e entrega impecável em até 20 dias" />
  <About client:visible />
  <Testimonials client:visible />
  <InlineCTA client:visible text="Falar com o Yan" subtitle="Conecte-se diretamente comigo pelo WhatsApp para tirar suas dúvidas" />
  <HowItWorks client:visible />
  <CTA client:visible />
</main>
<Footer client:visible />
<FloatingWhatsApp client:idle />

  </body>
</html>
